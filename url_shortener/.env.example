# url_shortener service-specific settings.
# Stack-wide vars (DOMAIN, CERT_RESOLVER, SITE_NAME, etc.) live in the root .env.
# Run `make setup` from the repo root to create both files.

DEBUG=True
DJANGO_SECRET_KEY=your-secret-key-here

DB_HOST=db
DB_PORT=5432
DB_NAME=shortener
DB_USER=postgres
DB_PASSWORD=postgres
