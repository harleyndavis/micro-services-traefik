# Must match traefik/.env values.
# HOME_URL is derived from this automatically as https://www.{TRAEFIK_DASHBOARD_HOST}
# and is used in nav templates to link "Home" back to the main site. No need to set it separately.
TRAEFIK_DASHBOARD_HOST=dev.localhost
CERT_RESOLVER=

# App-specific vars below.

# Django settings
DEBUG=True
DJANGO_SECRET_KEY=your-secret-key-here
HOME_URL=https://www.dev.localhost

# Database
DB_HOST=db
DB_PORT=5432
DB_NAME=shortener
DB_USER=postgres
DB_PASSWORD=postgres
