# TRAEFIK_DASHBOARD_HOST and CERT_RESOLVER come from traefik/.env automatically.
# Only set app-specific vars here.

# Django settings
DEBUG=True
DJANGO_SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1,short.dev.localhost,dev.localhost

# Database
DB_HOST=db
DB_PORT=5432
DB_NAME=shortener
DB_USER=postgres
DB_PASSWORD=postgres

# CORS
CORS_ALLOWED_ORIGINS=https://short.dev.localhost,https://dev.localhost,http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=https://short.dev.localhost,https://dev.localhost,http://localhost,http://127.0.0.1
