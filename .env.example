# Stack-wide configuration — copy to .env and adjust for your environment.
# The Makefile passes this file to every service via --env-file .env.
# Run `make setup` to create .env from this file.

# ── Routing & TLS ──────────────────────────────────────────────────────────────

DOMAIN=dev.localhost

# Leave both empty for local dev (mkcert certs via traefik/dynamic/tls.yaml).
# For production: set a real email and CERT_RESOLVER=letsencrypt.
ACME_EMAIL=
CERT_RESOLVER=

# ── Brand / site identity ──────────────────────────────────────────────────────

# Brand name shown in header, footer, and page titles across all services.
# Defaults to DOMAIN if unset.
SITE_NAME=hrly.sh

# Use &amp; instead of & in SITE_TAGLINE so it renders correctly as HTML.
SITE_TAGLINE=BUILT WITH CAFFEINE &amp; CURIOSITY

# Personal info used on the static site landing page.
AUTHOR_NAME=Your Name
AUTHOR_EMAIL=you@example.com
GITHUB_URL=https://github.com/yourname
GITHUB_HANDLE=@yourname
LINKEDIN_URL=https://linkedin.com/in/yourname
LINKEDIN_HANDLE=in/yourname
